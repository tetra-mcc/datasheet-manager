# Copy this file to .env and fill in your real credentials.

# SQLAlchemy dialect+driver.
#   Postgres (current):  postgresql+psycopg2
#   MS SQL  (future):    mssql+pyodbc   (also set DB_ODBC_DRIVER below)
DB_DIALECT=postgresql+psycopg2

DB_HOST=localhost
DB_PORT=5432
DB_NAME=product_db
DB_USER=username
DB_PASSWORD=password

# Only needed for MS SQL (mssql+pyodbc), e.g. "ODBC Driver 18 for SQL Server"
DB_ODBC_DRIVER=

# Where downloaded datasheets are stored (local for now; blob storage later).
# resource.path is stored relative to this directory.
DATASHEET_DIR=output/datasheets
